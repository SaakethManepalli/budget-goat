PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here

# sandbox | development | production
# Production deployment MUST set this to "production".
PLAID_ENV=sandbox

# Comma-separated. Full list: https://plaid.com/docs/api/link/#link-token-create-request-products
PLAID_PRODUCTS=transactions

# Required in production. Must be an https:// Universal Link in production.
# Sandbox can use a custom URL scheme like: budgetgoat://plaid-oauth
# PLAID_REDIRECT_URI=https://budgetgoat.app/plaid-oauth

PORT=8787

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=64_hex_chars_here
JWT_SECRET=64_hex_chars_here

# NODE_ENV must be "production" for live deployments.
# Fly.io sets this automatically in fly.toml [env] section.
NODE_ENV=development
